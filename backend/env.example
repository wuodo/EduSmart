# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/edusmart?schema=public"

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Password Reset Secret
RESET_SECRET=your_reset_secret_key_change_this_in_production

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880 # 5MB in bytes

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# SMTP Mail Configuration (required for digests, email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@edusmart.app

# Frontend URL (used in notification links)
FRONTEND_URL=http://localhost:3000

# AI / LLM Configuration (optional — for AI-powered sentiment & recommendations)
# Provider: "openai" (default) or "groq"
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini